!vendor/**/zz_generated.*

# editor and IDE paraphernalia
.idea
.vscode
*.swp
*.swo
*~

# OLM / opm build artifacts (generated locally, not source)
bundle_tmp*/
database/
index.Dockerfile
index.Dockerfile*
catalog/
dist/
cover.out
